{
  "name": "billing-sys",
  "version": "1.0.2",
  "description": "Desktop billing software with Electron + React + SQLite",
  "author": "Nirav Vasani",
  "main": "electron-main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && set ELECTRON_RUN_AS_NODE=&& cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "start": "set ELECTRON_RUN_AS_NODE=&& electron .",
    "build": "vite build",
    "pack": "npm run build && electron-builder --dir",
    "dist:win": "npm run build && electron-builder --win nsis",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.6.1",
    "better-sqlite3": "^11.8.1",
    "electron-updater": "^6.8.3",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-redux": "^9.1.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^36.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.18",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.riva.billingsys",
    "productName": "Billing System",
    "publish": [
      {
        "provider": "github",
        "owner": "Niravvasani12",
        "repo": "billing-system"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-main.js",
      "preload.js",
      "backend/**/*",
      "ipc/**/*",
      "config/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}